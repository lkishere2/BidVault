<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.app.controllers.auth.VerificationBoxController">
    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
    </padding>
    <children>
        <VBox spacing="4.0">
            <children>
                <Label text="Verify Your Account" textFill="#1a1a1a">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Label text="Enter the 6-digit activation code sent to you" textFill="#666666">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </children>
            <VBox.margin>
                <Insets bottom="4.0" />
            </VBox.margin>
        </VBox>

        <VBox spacing="6.0">
            <children>
                <Label text="Email Address" textFill="#4d4d4d">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <TextField fx:id="emailField" promptText="name@example.com" style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-background-color: #fafafa;" />
            </children>
        </VBox>

        <VBox spacing="6.0">
            <children>
                <Label text="Verification Code" textFill="#4d4d4d">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <TextField fx:id="codeField" alignment="CENTER" promptText="123456" style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-background-color: #fafafa; -fx-font-size: 16; -fx-font-weight: bold; -fx-letter-spacing: 4;" />
            </children>
        </VBox>

        <Button fx:id="verifyButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleVerify" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 4; -fx-cursor: hand;" text="Activate Account">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </Button>

        <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="8.0">
            <children>
                <Hyperlink onAction="#handleResendCode" style="-fx-text-fill: #dc3545;" text="Didn't get a code? Resend Email" />
                <Hyperlink onAction="#navigateToLogin" style="-fx-text-fill: #666666;" text="Back to Sign In" />
            </children>
            <VBox.margin>
                <Insets top="4.0" />
            </VBox.margin>
        </VBox>
    </children>
</VBox>