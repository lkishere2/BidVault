<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.auth.LoginBoxController">
    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
    </padding>
    <children>
        <VBox spacing="4.0">
            <children>
                <Label text="Welcome Back" textFill="#1a1a1a">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Label text="Please enter your details to sign in" textFill="#666666">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </children>
            <VBox.margin>
                <Insets bottom="8.0" />
            </VBox.margin>
        </VBox>

        <VBox spacing="6.0">
            <children>
                <Label text="Email Address" textFill="#4d4d4d">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <TextField fx:id="emailField" promptText="you@example.com" style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-background-color: #fafafa;" />
            </children>
        </VBox>

        <VBox spacing="6.0">
            <children>
                <Label text="Password" textFill="#4d4d4d">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <PasswordField fx:id="passwordField" promptText="••••••••" style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-background-color: #fafafa;" />
            </children>
        </VBox>

        <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 4; -fx-cursor: hand;" text="Sign In">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </Button>

        <VBox alignment="CENTER" maxWidth="1.7976931348623157E308">
            <children>
                <Hyperlink onAction="#navigateToRegister" style="-fx-text-fill: #007bff;" text="Don't have an account? Sign up" />
            </children>
            <VBox.margin>
                <Insets top="4.0" />
            </VBox.margin>
        </VBox>
    </children>
</VBox>