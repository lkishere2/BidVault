<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.AccountNavbarController"
      spacing="4"
      style="-fx-background-color: #111111;
             -fx-border-color: transparent rgba(255,255,255,0.06) transparent transparent;
             -fx-border-width: 0 0.5 0 0;
             -fx-pref-width: 220;">

    <padding>
        <Insets top="24" right="12" bottom="20" left="12"/>
    </padding>

    <!-- Logo / app brand -->
    <VBox spacing="2" style="-fx-padding: 0 8 20 8;">
        <Label text="BidVault"
               style="-fx-text-fill: #F5C518; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label text="TRADING PLATFORM"
               style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 9px; -fx-font-weight: bold;"/>
    </VBox>

    <!-- Thin divider -->
    <Region prefHeight="0.5" maxWidth="Infinity"
            style="-fx-background-color: rgba(255,255,255,0.06); -fx-margin: 0 0 8 0;"/>

    <VBox spacing="2" style="-fx-padding: 8 0 0 0;">
        <fx:include fx:id="navProfile"   source="../../components/NavItem.fxml"/>
        <fx:include fx:id="navBalance"   source="../../components/NavItem.fxml"/>
        <fx:include fx:id="navInventory" source="../../components/NavItem.fxml"/>
        <fx:include fx:id="navNotifications" source="../../components/NavItem.fxml"/>
        <fx:include fx:id="navSettings"  source="../../components/NavItem.fxml"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Bottom divider -->
    <Region prefHeight="0.5" maxWidth="Infinity"
            style="-fx-background-color: rgba(255,255,255,0.06);"/>

    <VBox style="-fx-padding: 8 0 0 0;">
        <fx:include fx:id="navBack" source="../../components/NavItem.fxml"/>
    </VBox>

</VBox>
