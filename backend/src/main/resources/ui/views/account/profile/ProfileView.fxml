<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.account.profile.ProfileViewController"
      spacing="0"
      style="-fx-background-color: #0D0D0D;"
      VBox.vgrow="ALWAYS">

    <padding>
        <Insets top="28" right="28" bottom="20" left="28"/>
    </padding>

    <fx:include fx:id="userStatsBox" source="UserStatsBox.fxml"/>

    <!-- Divider with grid icon row — like Instagram tab bar -->
    <VBox style="-fx-padding: 0 0 0 0;">
        <!-- thin gold line separator -->
        <VBox prefHeight="0.5" maxWidth="Infinity"
              style="-fx-background-color: rgba(245,197,24,0.20); -fx-margin: 18 0 0 0;"/>
    </VBox>

    <fx:include fx:id="auctionGrid" source="AuctionGrid.fxml"/>

</VBox>
