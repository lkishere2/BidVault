<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.auction.app.controllers.account.profile.AuctionItemController"
           prefWidth="180.0" prefHeight="180.0" fx:id="rootPane"
           style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-cursor: hand;">

    <ImageView fx:id="postImageView" fitWidth="178.0" fitHeight="178.0" pickOnBounds="true"/>

    <VBox fx:id="hoverOverlay" alignment="CENTER" spacing="4" visible="false"
          style="-fx-background-color: rgba(15, 23, 42, 0.75); -fx-background-radius: 7;">
        <Label fx:id="overlayTitleLabel" text="Product Title" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;" wrapText="true" alignment="CENTER"/>
        <Label fx:id="overlayPriceLabel" text="Price Label" style="-fx-text-fill: #34D399; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        <Label fx:id="overlayStatusLabel" text="ACTIVE" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-color: rgba(255,255,255,0.15); -fx-padding: 2 6; -fx-background-radius: 4;"/>
    </VBox>
</StackPane>