<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Instagram-style square post tile -->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.auction.app.controllers.account.profile.AuctionItemController"
           prefWidth="196.0" prefHeight="196.0"
           fx:id="rootPane"
           style="-fx-background-color: #1A1A1A;
                  -fx-cursor: hand;">

    <!-- Full-bleed image -->
    <ImageView fx:id="postImageView"
               fitWidth="196.0" fitHeight="196.0"
               pickOnBounds="true" preserveRatio="false"/>

    <!-- Status badge — top right corner, always visible -->
    <VBox alignment="TOP_RIGHT" maxWidth="Infinity" maxHeight="Infinity"
          mouseTransparent="true">
        <padding>
            <Insets top="8" right="8"/>
        </padding>
        <Label fx:id="overlayStatusLabel" text="ACTIVE"
               style="-fx-font-size: 9px; -fx-font-weight: bold;
                      -fx-text-fill: #0D0D0D;
                      -fx-background-color: #F5C518;
                      -fx-background-radius: 4;
                      -fx-padding: 3 7;"/>
    </VBox>

    <!-- Hover overlay — dark scrim with title + price, like Instagram post hover -->
    <VBox fx:id="hoverOverlay"
          alignment="CENTER" spacing="5"
          visible="false"
          maxWidth="Infinity" maxHeight="Infinity"
          style="-fx-background-color: rgba(0,0,0,0.72);">

        <!-- Gold price — big and central -->
        <Label fx:id="overlayPriceLabel" text="0.00"
               style="-fx-text-fill: #F5C518;
                      -fx-font-weight: bold;
                      -fx-font-size: 18px;"/>

        <!-- Title -->
        <Label fx:id="overlayTitleLabel" text="Product Title"
               style="-fx-text-fill: #FFFFFF;
                      -fx-font-weight: bold;
                      -fx-font-size: 12px;"
               wrapText="true"
               alignment="CENTER"
               maxWidth="176"/>

        <!-- Divider -->
        <Region prefHeight="0.5" prefWidth="40"
                style="-fx-background-color: rgba(245,197,24,0.40);"/>

        <!-- Stat row — like Instagram likes/comments bar -->
        <HBox spacing="14" alignment="CENTER">
            <Label text="🔨"
                   style="-fx-font-size: 11px;"/>
            <Label fx:id="overlayLiveLabel" text="LIVE"
                   style="-fx-text-fill: rgba(255,255,255,0.60);
                          -fx-font-size: 10px; -fx-font-weight: bold;"/>
        </HBox>

    </VBox>

</StackPane>
