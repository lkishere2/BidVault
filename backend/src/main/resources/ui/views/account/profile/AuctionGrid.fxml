<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.account.profile.AuctionGridController"
      spacing="14" VBox.vgrow="ALWAYS">

    <!-- Tab bar — Instagram grid icon style -->
    <HBox alignment="CENTER"
          style="-fx-padding: 12 0 12 0;
                 -fx-border-color: transparent transparent rgba(255,255,255,0.07) transparent;
                 -fx-border-width: 0 0 0.5 0;">
        <Label text="⊞  Auctions"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #F5C518;
                      -fx-padding: 0 0 10 0;
                      -fx-border-color: transparent transparent #F5C518 transparent;
                      -fx-border-width: 0 0 2 0;"/>
    </HBox>

    <!-- Grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-background-insets: 0; -fx-padding: 0;">
        <FlowPane fx:id="gridFlowPane" hgap="3" vgap="3"
                  style="-fx-background-color: transparent;"/>
    </ScrollPane>

    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="12" style="-fx-padding: 6 0 0 0;">
        <Button fx:id="prevGridBtn" text="◄" onAction="#handlePreviousGridPage"
                style="-fx-background-color: #1A1A1A; -fx-text-fill: rgba(255,255,255,0.50);
                       -fx-font-size: 11px;
                       -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-border-width: 0.5; -fx-cursor: hand; -fx-padding: 7 14;"/>
        <Label fx:id="gridPageLabel" text="Page 1 of 1"
               style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.35); -fx-font-weight: bold; -fx-padding: 0 8;"/>
        <Button fx:id="nextGridBtn" text="►" onAction="#handleNextGridPage"
                style="-fx-background-color: #1A1A1A; -fx-text-fill: rgba(255,255,255,0.50);
                       -fx-font-size: 11px;
                       -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-border-width: 0.5; -fx-cursor: hand; -fx-padding: 7 14;"/>
    </HBox>

</VBox>
