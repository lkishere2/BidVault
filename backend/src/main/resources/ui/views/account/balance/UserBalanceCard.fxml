<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.balance.UserBalanceCardController"
      spacing="15.0"
      style="-fx-background-color: #1E293B; -fx-background-radius: 12px; -fx-border-color: #334155; -fx-border-radius: 12px; -fx-border-width: 1px;"
      prefWidth="790.0">

    <padding>
        <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="Available Balance" textFill="#94A3B8">
                <font>
                    <Font name="System Bold" size="14.0"/>
                </font>
            </Label>
            <Label fx:id="balanceAmountLabel" text="0.00" textFill="#F8FAFC">
                <font>
                    <Font name="System Bold" size="32.0"/>
                </font>
            </Label>
        </VBox>

        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Button text="+ Deposit"
                    onAction="#handleOpenDepositModal"
                    style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;"
                    prefHeight="40.0">
                <padding>
                    <Insets left="20.0" right="20.0"/>
                </padding>
            </Button>
            <Button text="- Withdraw"
                    onAction="#handleOpenWithdrawalModal"
                    style="-fx-background-color: #F43F5E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;"
                    prefHeight="40.0">
                <padding>
                    <Insets left="20.0" right="20.0"/>
                </padding>
            </Button>
        </HBox>
    </HBox>
</VBox>