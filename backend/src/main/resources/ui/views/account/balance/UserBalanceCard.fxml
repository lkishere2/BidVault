<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.balance.UserBalanceCardController"
      spacing="0"
      style="-fx-background-color: #1A1A1A; -fx-background-radius: 10px; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 10px; -fx-border-width: 0.5px;"
      prefWidth="794.0">

    <padding>
        <Insets top="22.0" right="24.0" bottom="22.0" left="24.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="0">

        <!-- Left: label + balance -->
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label text="Available Balance"
                   style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 11px; -fx-font-weight: normal;"/>
            <HBox spacing="10.0" alignment="BASELINE_LEFT">
                <Label fx:id="balanceAmountLabel" text="0.00"
                       style="-fx-text-fill: #F5C518; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                <Label text="USD"
                       style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 13px;"/>
            </HBox>
        </VBox>

        <!-- Right: action buttons -->
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Button text="+ Deposit"
                    onAction="#handleOpenDepositModal"
                    style="-fx-background-color: #F5C518; -fx-text-fill: #0D0D0D; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;"
                    prefHeight="38.0">
                <padding>
                    <Insets top="0" right="20.0" bottom="0" left="20.0"/>
                </padding>
            </Button>
            <Button text="- Withdraw"
                    onAction="#handleOpenWithdrawalModal"
                    style="-fx-background-color: transparent; -fx-text-fill: #F5C518; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-color: rgba(245,197,24,0.30); -fx-border-radius: 6px; -fx-border-width: 1px; -fx-cursor: hand;"
                    prefHeight="38.0">
                <padding>
                    <Insets top="0" right="20.0" bottom="0" left="20.0"/>
                </padding>
            </Button>
        </HBox>

    </HBox>
</VBox>

