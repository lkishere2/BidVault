<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.balance.BalanceRequestBoxController"
      style="-fx-background-color: #1A1A1A; -fx-background-radius: 10px; -fx-border-color: rgba(245,197,24,0.30); -fx-border-width: 1px; -fx-border-radius: 10px;"
      maxWidth="400.0" maxHeight="280.0" prefWidth="400.0" spacing="20.0" alignment="CENTER">
    <padding>
        <Insets top="26.0" right="26.0" bottom="26.0" left="26.0"/>
    </padding>

    <!-- Title block -->
    <VBox spacing="6.0" alignment="CENTER_LEFT">
        <Label fx:id="modalTitleLabel" text="TRANSACTION REQUEST"
               style="-fx-text-fill: #F5C518; -fx-font-size: 15px; -fx-font-weight: bold;
                      -fx-letter-spacing: 0.06em;">
            <font><Font name="System Bold" size="15.0"/></font>
        </Label>
        <Label fx:id="modalDescriptionLabel"
               text="Provide an amount to forward to the platform admin ledger."
               style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 12px;"
               wrapText="true"/>
    </VBox>

    <!-- Amount input -->
    <VBox spacing="8.0">
        <Label text="Amount (USD)"
               style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <TextField fx:id="amountInputField" promptText="0.00"
                   style="-fx-background-color: #0D0D0D; -fx-text-fill: #FFFFFF;
                          -fx-prompt-text-fill: rgba(255,255,255,0.25);
                          -fx-background-radius: 6px;
                          -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 6px; -fx-border-width: 0.5px;
                          -fx-font-size: 14px;">
            <padding>
                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0"/>
            </padding>
        </TextField>
        <Label fx:id="errorMessageLabel"
               style="-fx-text-fill: #FF4D4D; -fx-font-size: 11px;"
               visible="false" wrapText="true"/>
    </VBox>

    <!-- Actions -->
    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCloseModal"
                style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.40);
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button fx:id="actionSubmitButton" text="Confirm Request" onAction="#handleSubmitTransaction"
                style="-fx-background-color: #F5C518; -fx-text-fill: #0D0D0D;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-background-radius: 6px; -fx-cursor: hand;">
            <padding>
                <Insets top="10.0" right="18.0" bottom="10.0" left="18.0"/>
            </padding>
        </Button>
    </HBox>
</VBox>

