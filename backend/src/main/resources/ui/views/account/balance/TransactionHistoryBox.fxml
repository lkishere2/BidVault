<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.balance.TransactionHistoryBoxController"
      spacing="0"
      style="-fx-background-color: #141414; -fx-background-radius: 10px; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 10px; -fx-border-width: 0.5px;"
      prefWidth="794.0">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-border-color: transparent transparent rgba(255,255,255,0.08) transparent; -fx-border-width: 0 0 0.5 0;">
        <padding>
            <Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/>
        </padding>

        <Label text="Transaction History"
               style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;">
            <font><Font name="System Bold" size="14.0"/></font>
        </Label>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Ticker accent -->
        <Label text="● LIVE"
               style="-fx-text-fill: #F5C518; -fx-font-size: 10px; -fx-font-weight: bold;
                      -fx-background-color: rgba(245,197,24,0.10); -fx-background-radius: 20px;
                      -fx-padding: 4 10 4 10;"/>
    </HBox>

    <!-- TableView — keeps your exact fx:id names and stylesheet -->
    <TableView fx:id="transactionTable"
               stylesheets="@../../../styles/tableview.css"
               prefHeight="310.0"
               style="-fx-background-color: transparent; -fx-table-cell-border-color: rgba(255,255,255,0.05);">
        <columns>
            <TableColumn fx:id="typeColumn"   text="TYPE"   prefWidth="130.0"/>
            <TableColumn fx:id="amountColumn" text="AMOUNT" prefWidth="160.0"/>
            <TableColumn fx:id="statusColumn" text="STATUS" prefWidth="130.0"/>
            <TableColumn fx:id="dateColumn"   text="DATE"   prefWidth="374.0"/>
        </columns>
    </TableView>

    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="10.0"
          style="-fx-border-color: rgba(255,255,255,0.08) transparent transparent transparent; -fx-border-width: 0.5 0 0 0;">
        <padding>
            <Insets top="14.0" right="20.0" bottom="14.0" left="20.0"/>
        </padding>

        <Button fx:id="previousPageButton" text="← Prev" onAction="#loadPreviousPage"
                style="-fx-background-color: #1A1A1A; -fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 6px; -fx-border-width: 0.5px; -fx-cursor: hand;">
            <padding>
                <Insets top="7.0" right="16.0" bottom="7.0" left="16.0"/>
            </padding>
        </Button>

        <Label fx:id="pageIndexIndicatorLabel" text="Page 1 of 1"
               style="-fx-text-fill: rgba(255,255,255,0.40); -fx-font-size: 12px; -fx-padding: 0 8 0 8;"/>

        <Button fx:id="nextPageButton" text="Next →" onAction="#loadNextPage"
                style="-fx-background-color: #1A1A1A; -fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 6px; -fx-border-width: 0.5px; -fx-cursor: hand;">
            <padding>
                <Insets top="7.0" right="16.0" bottom="7.0" left="16.0"/>
            </padding>
        </Button>
    </HBox>

</VBox>
