<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.account.inventory.ProductItemController"
      prefWidth="210.0" prefHeight="310.0"
      style="-fx-background-color: #1A1A1A;
             -fx-background-radius: 10;
             -fx-border-radius: 10;
             -fx-border-color: rgba(255,255,255,0.08);
             -fx-border-width: 0.5;
             -fx-cursor: hand;">

    <padding>
        <Insets top="12" right="12" bottom="14" left="12"/>
    </padding>

    <!-- Image area -->
    <VBox alignment="CENTER" prefHeight="136.0"
          style="-fx-background-color: #111111; -fx-background-radius: 7;">
        <ImageView fx:id="productImageView"
                   fitWidth="186.0" fitHeight="116.0"
                   pickOnBounds="true" preserveRatio="true"/>
    </VBox>

    <!-- Content -->
    <VBox spacing="7" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="11"/>
        </padding>

        <!-- Name -->
        <Label fx:id="productNameLabel"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"
               wrapText="false"/>

        <!-- Category tag row -->
        <HBox spacing="4" alignment="CENTER_LEFT" fx:id="tagsContainer"/>

        <!-- Divider line -->
        <Region prefHeight="0.5"
                style="-fx-background-color: rgba(255,255,255,0.07);"
                maxWidth="Infinity"/>

        <!-- Stock row -->
        <HBox alignment="CENTER_LEFT" VBox.vgrow="ALWAYS">
            <Label text="Stock  "
                   style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.40);"/>
            <Label fx:id="quantityLabel"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #F5C518;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Launch button -->
        <Button text="Launch Auction" onAction="#handleCreateAuctionClick" maxWidth="Infinity"
                style="-fx-background-color: #F5C518; -fx-text-fill: #0D0D0D;
                       -fx-font-size: 12px; -fx-font-weight: bold;
                       -fx-background-radius: 6; -fx-padding: 9 0; -fx-cursor: hand;"/>
    </VBox>

</VBox>
