<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.account.inventory.CreateAuctionBoxController"
      spacing="18" prefWidth="500.0"
      style="-fx-background-color: #1A1A1A;
             -fx-background-radius: 12;
             -fx-border-radius: 12;
             -fx-border-color: rgba(245,197,24,0.25);
             -fx-border-width: 1;">

    <padding>
        <Insets top="26" right="26" bottom="26" left="26"/>
    </padding>

    <!-- Title -->
    <VBox spacing="5">
        <Label text="Launch Live Auction"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #F5C518;"/>
        <Label fx:id="productInfoSubtitle"
               text="Configuring market parameters for: [Product Name]"
               style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.45);"/>
    </VBox>

    <!-- Divider -->
    <Region prefHeight="0.5" maxWidth="Infinity"
            style="-fx-background-color: rgba(255,255,255,0.07);"/>

    <!-- Fields -->
    <HBox spacing="14">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Auction Quantity *"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.55);"/>
            <TextField fx:id="quantityField" promptText="Must be &lt;= Available Stock"
                       style="-fx-background-color: #111111; -fx-text-fill: #FFFFFF;
                              -fx-prompt-text-fill: rgba(255,255,255,0.22);
                              -fx-background-radius: 7; -fx-border-radius: 7;
                              -fx-border-color: rgba(255,255,255,0.10); -fx-border-width: 0.5;
                              -fx-padding: 10 12; -fx-font-size: 13px;"/>
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Starting Price (USD) *"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.55);"/>
            <TextField fx:id="priceField" promptText="0.00"
                       style="-fx-background-color: #111111; -fx-text-fill: #FFFFFF;
                              -fx-prompt-text-fill: rgba(255,255,255,0.22);
                              -fx-background-radius: 7; -fx-border-radius: 7;
                              -fx-border-color: rgba(255,255,255,0.10); -fx-border-width: 0.5;
                              -fx-padding: 10 12; -fx-font-size: 13px;"/>
        </VBox>
    </HBox>

    <VBox spacing="5">
        <Label text="Start Date &amp; Time *"
               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.55);"/>
        <HBox spacing="8">
            <DatePicker fx:id="startDatePicker" promptText="Select Date"
                        prefHeight="40.0" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-background-color: #111111; -fx-background-radius: 7; -fx-border-radius: 7;
                               -fx-border-color: rgba(255,255,255,0.10); -fx-border-width: 0.5;"/>
            <ComboBox fx:id="startHourBox" promptText="HH" prefHeight="40.0"
                      style="-fx-background-color: #111111; -fx-background-radius: 7; -fx-border-radius: 7;
                             -fx-border-color: rgba(255,255,255,0.10); -fx-border-width: 0.5;"/>
            <ComboBox fx:id="startMinuteBox" promptText="MM" prefHeight="40.0"
                      style="-fx-background-color: #111111; -fx-background-radius: 7; -fx-border-radius: 7;
                             -fx-border-color: rgba(255,255,255,0.10); -fx-border-width: 0.5;"/>
        </HBox>
    </VBox>

    <VBox spacing="5">
        <Label text="End Date &amp; Time *"
               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.55);"/>
        <HBox spacing="8">
            <DatePicker fx:id="endDatePicker" promptText="Select Date"
                        prefHeight="40.0" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-background-color: #111111; -fx-background-radius: 7; -fx-border-radius: 7;
                               -fx-border-color: rgba(255,255,255,0.10); -fx-border-width: 0.5;"/>
            <ComboBox fx:id="endHourBox" promptText="HH" prefHeight="40.0"
                      style="-fx-background-color: #111111; -fx-background-radius: 7; -fx-border-radius: 7;
                             -fx-border-color: rgba(255,255,255,0.10); -fx-border-width: 0.5;"/>
            <ComboBox fx:id="endMinuteBox" promptText="MM" prefHeight="40.0"
                      style="-fx-background-color: #111111; -fx-background-radius: 7; -fx-border-radius: 7;
                             -fx-border-color: rgba(255,255,255,0.10); -fx-border-width: 0.5;"/>
        </HBox>
    </VBox>

    <Label fx:id="errorLabel"
           style="-fx-text-fill: #FF4D4D; -fx-font-size: 11px;"
           visible="false" managed="false" wrapText="true"/>

    <!-- Actions -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Cancel" onAction="#handleCancel"
                style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.40);
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 18;"/>
        <Button text="Create Auction Event" onAction="#handleCreateAuction"
                style="-fx-background-color: #F5C518; -fx-text-fill: #0D0D0D;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-background-radius: 7; -fx-cursor: hand; -fx-padding: 10 22;"/>
    </HBox>

</VBox>
