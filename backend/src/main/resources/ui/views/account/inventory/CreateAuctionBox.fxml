<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.account.inventory.CreateAuctionBoxController"
      spacing="16" prefWidth="480.0"
      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-radius: 16;">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <VBox spacing="4">
        <Label text="Launch Live Auction" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
        <Label fx:id="productInfoSubtitle" text="Configuring market parameters for: [Product Name]" style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
    </VBox>

    <HBox spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Auction Quantity*" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="quantityField" promptText="Must be &lt;= Available Stock" style="-fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8;"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Starting Price ($)*" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="priceField" promptText="0.00" style="-fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8;"/>
        </VBox>
    </HBox>

    <VBox spacing="4">
        <Label text="Start Date &amp; Time*" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
        <HBox spacing="8">
            <DatePicker fx:id="startDatePicker" promptText="Select Date" prefHeight="38.0" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <ComboBox fx:id="startHourBox" promptText="HH" prefHeight="38.0"/>
            <ComboBox fx:id="startMinuteBox" promptText="MM" prefHeight="38.0"/>
        </HBox>
    </VBox>

    <VBox spacing="4">
        <Label text="End Date &amp; Time*" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
        <HBox spacing="8">
            <DatePicker fx:id="endDatePicker" promptText="Select Date" prefHeight="38.0" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <ComboBox fx:id="endHourBox" promptText="HH" prefHeight="38.0"/>
            <ComboBox fx:id="endMinuteBox" promptText="MM" prefHeight="38.0"/>
        </HBox>
    </VBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: #EF4444; -fx-font-size: 12px;" visible="false" managed="false" wrapText="true"/>

    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Button text="Cancel" onAction="#handleCancel" style="-fx-padding: 10 20; -fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="Create Auction Event" onAction="#handleCreateAuction" style="-fx-padding: 10 20; -fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>
</VBox>