<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.account.inventory.ProductBoxController"
      spacing="16" prefWidth="440.0"
      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-radius: 16;">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <VBox spacing="4">
        <Label text="Product Workspace Console" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
        <Label text="Modify metadata fields, replace asset files, or delete this record." style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
    </VBox>

    <VBox spacing="12">
        <VBox spacing="4">
            <Label text="Product Name*" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
            <TextField fx:id="nameField" style="-fx-padding: 10; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Description" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
            <TextArea fx:id="descriptionArea" prefHeight="80.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1;" wrapText="true"/>
        </VBox>

        <HBox spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Stock Quantity*" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                <TextField fx:id="quantityField" style="-fx-padding: 10; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Category Tag*" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                <ComboBox fx:id="tagComboBox" prefHeight="42.0" maxWidth="Infinity" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1;"/>
            </VBox>
        </HBox>

        <VBox spacing="4">
            <Label text="Replace Product Image (Cloudinary Upload)" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="fileDestinationField" editable="false" mouseTransparent="true" focusTraversable="false"
                           promptText="Keep current image" HBox.hgrow="ALWAYS"
                           style="-fx-padding: 10; -fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1; -fx-text-fill: #64748B;"/>
                <Button text="Browse..." onAction="#handleFileChooseAction"
                        style="-fx-padding: 10 16; -fx-background-color: #F1F5F9; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: #EF4444; -fx-font-size: 12px;" visible="false" managed="false" wrapText="true"/>

    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Button text="Delete Product" onAction="#handleDelete"
                style="-fx-padding: 10 16; -fx-background-color: #FEF2F2; -fx-text-fill: #DC2626; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Cancel" onAction="#handleCancel"
                style="-fx-padding: 10 20; -fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="Save Changes" onAction="#handleUpdate"
                style="-fx-padding: 10 20; -fx-background-color: #0EA5E9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>
</VBox>