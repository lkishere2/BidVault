<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.account.inventory.InventoryViewController"
      spacing="20"
      style="-fx-background-color: #0D0D0D;">

    <padding>
        <Insets top="24" right="28" bottom="24" left="28"/>
    </padding>

    <!-- Header bar -->
    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #1A1A1A; -fx-background-radius: 10;
                 -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 10; -fx-border-width: 0.5;
                 -fx-padding: 18 22 18 22;">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Storage Inventory"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
            <Label text="Manage and register assets available for auction pipelines."
                   style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.45);"/>
        </VBox>
        <Button text="+ Add Product" onAction="#openAddProductModal"
                style="-fx-background-color: #F5C518; -fx-text-fill: #0D0D0D;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 10 22; -fx-background-radius: 7; -fx-cursor: hand;"/>
    </HBox>

    <!-- Product grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-background-insets: 0; -fx-padding: 0;">
        <FlowPane fx:id="productsFlowPane" hgap="16" vgap="16"
                  style="-fx-background-color: transparent;"/>
    </ScrollPane>

    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="12"
          style="-fx-padding: 4 0 0 0;">
        <Button fx:id="prevButton" text="← Previous" onAction="#handlePreviousPage"
                style="-fx-background-color: #1A1A1A; -fx-text-fill: rgba(255,255,255,0.55);
                       -fx-font-size: 12px; -fx-font-weight: bold;
                       -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-border-width: 0.5; -fx-cursor: hand; -fx-padding: 8 18;"/>
        <Label fx:id="pageInfoLabel" text="Page 1 of 1"
               style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.40); -fx-font-weight: bold; -fx-padding: 0 8;"/>
        <Button fx:id="nextButton" text="Next →" onAction="#handleNextPage"
                style="-fx-background-color: #1A1A1A; -fx-text-fill: rgba(255,255,255,0.55);
                       -fx-font-size: 12px; -fx-font-weight: bold;
                       -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-border-width: 0.5; -fx-cursor: hand; -fx-padding: 8 18;"/>
    </HBox>

</VBox>
