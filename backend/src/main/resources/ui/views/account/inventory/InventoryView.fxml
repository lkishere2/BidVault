<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.account.inventory.InventoryViewController"
      spacing="20" style="-fx-background-color: #F8FAFC;">

    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="My Storage Inventory" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
            <Label text="Manage and register items available for auction pipelines." style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
        </VBox>
        <Button text="+ Add Product" onAction="#openAddProductModal"
                style="-fx-background-color: #0EA5E9; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;">
        <FlowPane fx:id="productsFlowPane" hgap="16" vgap="16" style="-fx-background-color: transparent;"/>
    </ScrollPane>

    <HBox alignment="CENTER" spacing="16">
        <Button fx:id="prevButton" text="Previous" onAction="#handlePreviousPage" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Label fx:id="pageInfoLabel" text="Page 1 of 1" style="-fx-font-size: 13px; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
        <Button fx:id="nextButton" text="Next" onAction="#handleNextPage" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>
</VBox>