<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.settings.UserProfileCardController"
      fx:id="profileCardRoot"
      prefWidth="215" spacing="18" alignment="TOP_CENTER"
      style="-fx-background-color: #0D0D0D;
             -fx-background-radius: 18;
             -fx-border-color: #F5C518;
             -fx-border-radius: 18;
             -fx-border-width: 1.5;
             -fx-effect: dropshadow(gaussian, rgba(245,197,24,0.28), 24, 0.20, 0, 0);
             -fx-cursor: hand;">

    <padding>
        <Insets top="28" right="20" bottom="28" left="20"/>
    </padding>

    <!-- Avatar: gold ring → dark gap → image -->
    <StackPane alignment="CENTER">
        <VBox prefWidth="96" prefHeight="96" alignment="CENTER"
              style="-fx-background-color: #F5C518; -fx-background-radius: 100;">
            <VBox prefWidth="88" prefHeight="88" alignment="CENTER"
                  style="-fx-background-color: #0D0D0D; -fx-background-radius: 100;">
                <VBox prefWidth="80" prefHeight="80" alignment="CENTER"
                      style="-fx-background-color: #1A1A1A; -fx-background-radius: 100;">
                    <ImageView fx:id="avatarImageView"
                               fitWidth="80" fitHeight="80"
                               pickOnBounds="true" preserveRatio="true"/>
                </VBox>
            </VBox>
        </VBox>
    </StackPane>

    <!-- Username + badge -->
    <VBox spacing="7" alignment="CENTER">
        <Label fx:id="usernameLabel" text="Loading..."
               style="-fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        <Label text="✦  Verified Member"
               style="-fx-background-color: rgba(245,197,24,0.10);
                      -fx-text-fill: #F5C518; -fx-font-size: 10px; -fx-font-weight: bold;
                      -fx-padding: 4 12; -fx-background-radius: 20;
                      -fx-border-color: rgba(245,197,24,0.28);
                      -fx-border-radius: 20; -fx-border-width: 0.5;"/>
    </VBox>

    <!-- Gold divider -->
    <Region prefHeight="0.5" maxWidth="Infinity"
            style="-fx-background-color: rgba(245,197,24,0.18);"/>

    <!-- Balance — recessed inset chip -->
    <VBox spacing="4" alignment="CENTER"
          style="-fx-background-color: #080808;
                 -fx-background-radius: 10;
                 -fx-border-color: rgba(245,197,24,0.15);
                 -fx-border-radius: 10; -fx-border-width: 0.5;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.90), 10, 0, 0, 3);
                 -fx-padding: 12 20;">
        <Label text="BALANCE"
               style="-fx-text-fill: rgba(255,255,255,0.28);
                      -fx-font-size: 9px; -fx-font-weight: bold;"/>
        <Label fx:id="roleLabel" text="0.00"
               style="-fx-text-fill: #F5C518; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label text="Available"
               style="-fx-text-fill: rgba(255,255,255,0.20); -fx-font-size: 10px;"/>
    </VBox>

    <!-- Gold divider -->
    <Region prefHeight="0.5" maxWidth="Infinity"
            style="-fx-background-color: rgba(245,197,24,0.18);"/>

    <!-- Activity strip -->
    <VBox spacing="11">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="⬤" style="-fx-text-fill: #00D68F; -fx-font-size: 7px;"/>
            <Label text="Account Active"
                   style="-fx-text-fill: rgba(255,255,255,0.32); -fx-font-size: 11px;"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="⬤" style="-fx-text-fill: rgba(245,197,24,0.70); -fx-font-size: 7px;"/>
            <Label text="Verified Seller"
                   style="-fx-text-fill: rgba(255,255,255,0.32); -fx-font-size: 11px;"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="⬤" style="-fx-text-fill: rgba(100,160,255,0.70); -fx-font-size: 7px;"/>
            <Label text="BidVault Platform"
                   style="-fx-text-fill: rgba(255,255,255,0.32); -fx-font-size: 11px;"/>
        </HBox>
    </VBox>

</VBox>
