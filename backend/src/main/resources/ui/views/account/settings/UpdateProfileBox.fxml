<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.settings.UpdateProfileBoxController"
      spacing="16"
      style="-fx-background-color: transparent;">

    <!-- ─── CARD 1: Username ─── -->
    <VBox spacing="14"
          style="-fx-background-color: #0D0D0D;
                 -fx-background-radius: 16;
                 -fx-border-color: rgba(245,197,24,0.22);
                 -fx-border-radius: 16; -fx-border-width: 1;
                 -fx-effect: dropshadow(gaussian, rgba(245,197,24,0.14), 18, 0.12, 0, 4);">
        <padding>
            <Insets top="22" right="22" bottom="22" left="22"/>
        </padding>

        <VBox spacing="4">
            <Label text="ACCOUNT USERNAME"
                   style="-fx-text-fill: rgba(245,197,24,0.60);
                          -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <Label text="Change your public display name on the platform."
                   style="-fx-text-fill: rgba(255,255,255,0.28); -fx-font-size: 11px;"/>
        </VBox>

        <Region prefHeight="0.5" maxWidth="Infinity"
                style="-fx-background-color: rgba(255,255,255,0.06);"/>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="usernameField" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #080808;
                              -fx-text-fill: #FFFFFF;
                              -fx-prompt-text-fill: rgba(255,255,255,0.20);
                              -fx-background-radius: 8;
                              -fx-border-color: rgba(255,255,255,0.08);
                              -fx-border-radius: 8; -fx-border-width: 0.5;
                              -fx-font-size: 13px;
                              -fx-padding: 10 14;"/>
            <Button text="Save" onAction="#handleUsernameUpdate"
                    style="-fx-background-color: #F5C518;
                           -fx-text-fill: #0D0D0D;
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-padding: 10 22;"/>
        </HBox>
    </VBox>


    <!-- ─── CARD 3: Avatar ─── -->
    <VBox spacing="14"
          style="-fx-background-color: #0D0D0D;
                 -fx-background-radius: 16;
                 -fx-border-color: rgba(245,197,24,0.22);
                 -fx-border-radius: 16; -fx-border-width: 1;
                 -fx-effect: dropshadow(gaussian, rgba(245,197,24,0.14), 18, 0.12, 0, 4);">
        <padding>
            <Insets top="22" right="22" bottom="22" left="22"/>
        </padding>

        <VBox spacing="4">
            <Label text="PROFILE AVATAR"
                   style="-fx-text-fill: rgba(245,197,24,0.60);
                          -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <Label text="Upload a new profile image via Cloudinary."
                   style="-fx-text-fill: rgba(255,255,255,0.28); -fx-font-size: 11px;"/>
        </VBox>

        <Region prefHeight="0.5" maxWidth="Infinity"
                style="-fx-background-color: rgba(255,255,255,0.06);"/>

        <!-- Drop zone -->
        <VBox alignment="CENTER" spacing="8" prefHeight="90"
              style="-fx-background-color: #080808;
                     -fx-background-radius: 10;
                     -fx-border-color: rgba(245,197,24,0.25);
                     -fx-border-radius: 10; -fx-border-width: 1;
                     -fx-border-style: dashed;
                     -fx-effect: innershadow(gaussian, rgba(0,0,0,0.80), 8, 0, 0, 2);
                     -fx-cursor: hand;">
            <Label text="☁"
                   style="-fx-text-fill: rgba(245,197,24,0.35); -fx-font-size: 26px;"/>
            <TextField fx:id="fileSelectedPathField"
                       editable="false" mouseTransparent="true" focusTraversable="false"
                       promptText="No image file selected..."
                       style="-fx-background-color: transparent;
                              -fx-text-fill: rgba(255,255,255,0.45);
                              -fx-prompt-text-fill: rgba(255,255,255,0.22);
                              -fx-border-color: transparent;
                              -fx-font-size: 11px; -fx-alignment: CENTER;"
                       maxWidth="Infinity"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Browse File..." onAction="#handleChooseFile"
                    style="-fx-background-color: #1A1A1A;
                           -fx-text-fill: rgba(255,255,255,0.55);
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-border-color: rgba(255,255,255,0.10);
                           -fx-border-radius: 8; -fx-border-width: 0.5;
                           -fx-cursor: hand; -fx-padding: 9 18;"/>
            <Button fx:id="uploadImageButton" text="Upload Avatar"
                    onAction="#handleImageUpload" disable="true"
                    style="-fx-background-color: #F5C518;
                           -fx-text-fill: #0D0D0D;
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-padding: 9 20;"/>
        </HBox>
    </VBox>

    <!-- ─── CARD 4: Security ─── -->
    <VBox spacing="14"
          style="-fx-background-color: #0D0D0D;
                 -fx-background-radius: 16;
                 -fx-border-color: rgba(255,77,77,0.22);
                 -fx-border-radius: 16; -fx-border-width: 1;
                 -fx-effect: dropshadow(gaussian, rgba(255,77,77,0.10), 18, 0.10, 0, 4);">
        <padding>
            <Insets top="22" right="22" bottom="22" left="22"/>
        </padding>

        <VBox spacing="4">
            <Label text="SECURITY  ·  CHANGE PASSWORD"
                   style="-fx-text-fill: rgba(255,100,100,0.70);
                          -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <Label text="Update your login credentials. Both fields are required."
                   style="-fx-text-fill: rgba(255,255,255,0.28); -fx-font-size: 11px;"/>
        </VBox>

        <Region prefHeight="0.5" maxWidth="Infinity"
                style="-fx-background-color: rgba(255,255,255,0.06);"/>

        <VBox spacing="10">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="Request Verification Code" onAction="#handleRequestOTP"
                        style="-fx-background-color: #1A1A1A;
                               -fx-text-fill: rgba(255,255,255,0.55);
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-color: rgba(255,255,255,0.10);
                               -fx-border-radius: 8; -fx-border-width: 0.5;
                               -fx-cursor: hand; -fx-padding: 9 18;"/>
            </HBox>

            <TextField fx:id="verificationCodeField"
                           promptText="Enter 6-digit verification code"
                           style="-fx-background-color: #080808;
                                  -fx-text-fill: #FFFFFF;
                                  -fx-prompt-text-fill: rgba(255,255,255,0.20);
                                  -fx-background-radius: 8;
                                  -fx-border-color: rgba(255,255,255,0.08);
                                  -fx-border-radius: 8; -fx-border-width: 0.5;
                                  -fx-font-size: 13px;
                                  -fx-padding: 10 14;"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <PasswordField fx:id="passwordField" HBox.hgrow="ALWAYS"
                               promptText="Enter new password"
                               style="-fx-background-color: #080808;
                                      -fx-text-fill: #FFFFFF;
                                      -fx-prompt-text-fill: rgba(255,255,255,0.20);
                                      -fx-background-radius: 8;
                                      -fx-border-color: rgba(255,255,255,0.08);
                                      -fx-border-radius: 8; -fx-border-width: 0.5;
                                      -fx-font-size: 13px;
                                      -fx-padding: 10 14;"/>
                <Button text="Update Password" onAction="#handlePasswordUpdate"
                        style="-fx-background-color: rgba(255,77,77,0.85);
                               -fx-text-fill: #FFFFFF;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-cursor: hand;
                               -fx-padding: 10 18;"/>
            </HBox>
        </VBox>
    </VBox>

</VBox>

