<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.explore.UserAuctionItemController"
      spacing="10"
      prefWidth="190"
      style="-fx-background-color: #1A1A1A; -fx-background-radius: 12; -fx-border-color: rgba(245,197,24,0.35); -fx-border-radius: 12; -fx-padding: 12;">

    <StackPane prefWidth="166" prefHeight="126"
               style="-fx-background-color: #0D0D0D; -fx-background-radius: 8;">
        <ImageView fx:id="auctionImageView"
                   fitWidth="166" fitHeight="126"
                   preserveRatio="false"
                   pickOnBounds="true"/>
        <StackPane fx:id="imagePlaceholder"
                   prefWidth="166" prefHeight="126"
                   style="-fx-background-color: #111827; -fx-background-radius: 8;">
            <Label text="BidVault"
                   style="-fx-text-fill: #F5C518; -fx-font-weight: bold; -fx-font-size: 14;"/>
        </StackPane>
    </StackPane>

    <Label fx:id="titleLabel"
           wrapText="true"
           maxWidth="166"
           style="-fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-font-size: 13;"/>

    <Label fx:id="priceLabel"
           style="-fx-text-fill: #22C55E; -fx-font-weight: bold; -fx-font-size: 13;"/>

    <StackPane maxWidth="Infinity">
        <Label fx:id="statusLabel"
               StackPane.alignment="CENTER_LEFT"
               style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 6; -fx-text-fill: #E2E8F0; -fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 4 8;"/>
        <Label fx:id="bidsLabel"
               StackPane.alignment="CENTER_RIGHT"
               style="-fx-text-fill: #94A3B8; -fx-font-size: 11;"/>
    </StackPane>
</VBox>
