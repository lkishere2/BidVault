<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.app.controllers.explore.UserProfileController"
      spacing="28" alignment="TOP_LEFT" style="-fx-background-color: transparent;">

    <Button text="← Back to Search" onAction="#handleBackToSearch"
            style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-size: 14; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;"/>

    <HBox spacing="32" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 32; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 12, 0, 0, 4); -fx-border-color: #E2E8F0; -fx-border-radius: 16;">

        <ImageView fx:id="profileAvatarView" fitWidth="90.0" fitHeight="90.0" pickOnBounds="true" preserveRatio="true"/>

        <VBox spacing="16" HBox.hgrow="ALWAYS">
            <VBox spacing="4">
                <Label fx:id="profileUsername" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
            </VBox>

            <HBox spacing="24">
                <HBox spacing="6">
                    <Label fx:id="followersCountLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-font-size: 15;"/>
                    <Label text="followers" style="-fx-text-fill: #64748B; -fx-font-size: 15;"/>
                </HBox>
                <HBox spacing="6">
                    <Label fx:id="followingCountLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-font-size: 15;"/>
                    <Label text="following" style="-fx-text-fill: #64748B; -fx-font-size: 15;"/>
                </HBox>
            </HBox>
        </VBox>

        <Button fx:id="followButton" text="Follow" onAction="#handleToggleFollow"
                style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 24; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand;"/>
    </HBox>
</VBox>