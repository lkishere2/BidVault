<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:id="cardRoot"
      spacing="10" prefWidth="240" minWidth="240" maxWidth="240"
      onMouseClicked="#handleCardClick"
      style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Rectangle width="210" height="130" arcWidth="12" arcHeight="12" fill="#F1F5F9"/>

    <Label fx:id="statusTag" text="ACTIVE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4F46E5; -fx-background-color: #EEF2F6; -fx-padding: 3 8 3 8; -fx-background-radius: 4px;"/>

    <Label fx:id="titleLabel" text="Auction Item Title" wrapText="true" prefHeight="42" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>

    <VBox spacing="2">
        <Label text="Current Valued Price" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
        <Label fx:id="priceLabel" text="\$0.00" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #0F172A;"/>
    </VBox>
</VBox>
