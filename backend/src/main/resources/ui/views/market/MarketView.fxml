<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.market.MarketViewController"
      prefHeight="720.0" prefWidth="1080.0"
      style="-fx-background-color: #0D0D0D;"> <fx:include source="../home/Navbar.fxml"/>

    <VBox HBox.hgrow="ALWAYS">

        <fx:include fx:id="searchBar" source="MarketSearchBar.fxml"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: #0D0D0D; -fx-background-color: transparent;
                           -fx-viewport-background: transparent;">
            <content>
                <fx:include fx:id="auctionGrid" source="MarketAuctionGrid.fxml"/>
            </content>
        </ScrollPane>

        <HBox spacing="15" alignment="CENTER"
              style="-fx-padding: 14 20 14 20;
                     -fx-background-color: #0D0D0D; -fx-border-color: #F5C518; -fx-border-width: 1 0 0 0;">
            <Button fx:id="prevButton" text="← Previous" onAction="#handlePrevPage"
                    style="-fx-background-color: #FFFFFF; -fx-text-fill: #0D0D0D;
                           -fx-font-weight: bold;
                           -fx-background-radius: 6px;
                           -fx-cursor: hand;
                           -fx-padding: 7 16 7 16;"/>
            <Label fx:id="pageTrackerLabel" text="Page 1 of 1"
                   style="-fx-font-weight: bold;
                          -fx-text-fill: #F5C518;"/> <Button fx:id="nextButton" text="Next →" onAction="#handleNextPage"
                                                             style="-fx-background-color: #FFFFFF;
                           -fx-text-fill: #0D0D0D;
                           -fx-font-weight: bold;
                           -fx-background-radius: 6px;
                           -fx-cursor: hand;
                           -fx-padding: 7 16 7 16;"/>
        </HBox>

    </VBox>
</HBox>