<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.admin.AdminNavbarController"
      spacing="4"
      style="-fx-background-color: #111111;
             -fx-border-color: transparent rgba(255,255,255,0.06) transparent transparent;
             -fx-border-width: 0 0.5 0 0;
             -fx-pref-width: 220;">

    <padding>
        <Insets top="24" right="12" bottom="20" left="12"/>
    </padding>

    <!-- Brand header -->
    <VBox spacing="3" style="-fx-padding: 0 8 16 8;">
        <Label text="ADMIN CONSOLE"
               style="-fx-text-fill: #FF4D4D;
                      -fx-font-size: 13px; -fx-font-weight: bold;
                      -fx-effect: dropshadow(gaussian, rgba(255,77,77,0.55), 10, 0, 0, 0);"/>
        <Label text="PLATFORM CONTROL"
               style="-fx-text-fill: rgba(255,255,255,0.20);
                      -fx-font-size: 9px; -fx-font-weight: bold;"/>
    </VBox>

    <!-- Divider -->
    <Region prefHeight="0.5" maxWidth="Infinity"
            style="-fx-background-color: rgba(255,77,77,0.18);"/>

    <VBox spacing="2" style="-fx-padding: 10 0 0 0;">
        <fx:include fx:id="navTransactions" source="../../components/NavItem.fxml"/>
        <fx:include fx:id="navAuctions"     source="../../components/NavItem.fxml"/>
        <fx:include fx:id="navUsers"        source="../../components/NavItem.fxml"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Admin badge -->
    <HBox spacing="7" alignment="CENTER_LEFT" style="-fx-padding: 0 8 12 8;">
        <Label text="⬤"
               style="-fx-text-fill: #FF4D4D; -fx-font-size: 7px;"/>
        <Label text="ADMIN ACCESS"
               style="-fx-text-fill: rgba(255,77,77,0.60);
                      -fx-font-size: 10px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Divider -->
    <Region prefHeight="0.5" maxWidth="Infinity"
            style="-fx-background-color: rgba(255,255,255,0.06);"/>

    <VBox style="-fx-padding: 8 0 0 0;">
        <fx:include fx:id="navBack" source="../../components/NavItem.fxml"/>
    </VBox>

</VBox>
