<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ltnc.auction.ui.controller.AuthController"
    prefWidth="1000"
    prefHeight="700"
    stylesheets="/styles/auth.css">

    <!-- Main card -->
    <StackPane
        fx:id="authBox"
        opacity="0"
        translateY="50"
        maxWidth="800"
        maxHeight="550"
        styleClass="auth-box">

        <!-- RIGHT — Form section -->
        <StackPane
            fx:id="formSection"
            maxWidth="400"
            translateX="200"
            styleClass="form-section">

            <!-- REGISTER form -->
            <VBox
                fx:id="registerContainer"
                visible="false"
                managed="false"
                alignment="CENTER"
                spacing="15">
                <Label text="Create Account" styleClass="form-title"/>
                <TextField
                    fx:id="registerUsernameField"
                    promptText="Username"
                    styleClass="input-field"/>
                <TextField
                    fx:id="registerEmailField"
                    promptText="Email Address"
                    styleClass="input-field"/>
                <PasswordField
                    fx:id="registerPasswordField"
                    promptText="Password"
                    styleClass="input-field"/>
                <Label
                    fx:id="registerErrorLabel"
                    visible="false"
                    managed="false"
                    styleClass="error-label"/>
                <Button
                    fx:id="registerButton"
                    text="Sign Up"
                    maxWidth="Infinity"
                    onAction="#handleRegister"
                    styleClass="primary-button"/>
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Already a member?" styleClass="muted-text"/>
                    <Button
                        text="Sign in instead"
                        onAction="#goToLogin"
                        styleClass="link-button"/>
                </HBox>
            </VBox>

            <!-- LOGIN form -->
            <VBox
                fx:id="loginContainer"
                visible="true"
                managed="true"
                alignment="CENTER"
                spacing="15">
                <Label text="Welcome Back" styleClass="form-title"/>
                <TextField
                    fx:id="loginEmailField"
                    promptText="Email Address"
                    styleClass="input-field"/>
                <PasswordField
                    fx:id="loginPasswordField"
                    promptText="Password"
                    styleClass="input-field"/>
                <Label
                    fx:id="loginErrorLabel"
                    visible="false"
                    managed="false"
                    styleClass="error-label"/>
                <Button
                    fx:id="loginButton"
                    text="Sign In"
                    maxWidth="Infinity"
                    onAction="#handleLogin"
                    styleClass="primary-button"/>
                <HBox alignment="CENTER" spacing="5">
                    <Label text="New here?" styleClass="muted-text"/>
                    <Button
                        text="Create an account"
                        onAction="#goToRegister"
                        styleClass="link-button"/>
                </HBox>
            </VBox>

        </StackPane>

        <!-- LEFT — Branding section -->
        <VBox
            fx:id="brandingSection"
            maxWidth="400"
            translateX="-200"
            alignment="CENTER"
            spacing="20"
            styleClass="branding-section">
            <Text text="⚖" styleClass="branding-icon"/>
            <Label text="BidVault" styleClass="branding-title"/>
            <Label
                text="The Premier Online Auction"
                styleClass="branding-subtitle"
                wrapText="true"
                textAlignment="CENTER"/>
        </VBox>

    </StackPane>

    <!-- Intro overlay layer -->
    <AnchorPane
        fx:id="introLayer"
        mouseTransparent="true"
        styleClass="intro-layer">
        <StackPane
            fx:id="subSceneContainer"
            AnchorPane.bottomAnchor="0"
            AnchorPane.leftAnchor="0"
            AnchorPane.rightAnchor="0"
            AnchorPane.topAnchor="0"/>
    </AnchorPane>

</StackPane>