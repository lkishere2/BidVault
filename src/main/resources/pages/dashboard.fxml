<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.ltnc.auction.ui.controller.DashboardController"
    prefWidth="1100"
    prefHeight="700"
    stylesheets="/styles/dashboard.css">

    <!-- ── Navbar ── -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="⚖ BidVault" styleClass="navbar-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="navTimeLabel" styleClass="navbar-time"/>
            <Label fx:id="navBalanceLabel" styleClass="navbar-balance"/>
            <Label fx:id="navUserLabel" text="user #0" styleClass="navbar-user"/>
        </HBox>
    </top>

    <!-- ── Sidebar + Content ── -->
    <center>
        <HBox>

            <!-- ── Right sidebar ── -->
            <VBox styleClass="sidebar" spacing="0">
                <Button
                    fx:id="sidebarAuctions"
                    text="🏷  Active Auctions"
                    styleClass="sidebar-item, sidebar-item-active"
                    onAction="#showAuctions"/>
                <Separator styleClass="sidebar-divider"/>
                <Button
                    fx:id="sidebarInventory"
                    text="📦  Inventory"
                    styleClass="sidebar-item"
                    onAction="#showInventory"/>
                <Separator styleClass="sidebar-divider"/>
                <Button
                    fx:id="sidebarCreate"
                    text="➕  Create Auction"
                    styleClass="sidebar-item"
                    onAction="#showCreateAuction"/>
                <Separator styleClass="sidebar-divider"/>
                <Button
                    fx:id="sidebarProfile"
                    text="👤  Profile"
                    styleClass="sidebar-item"
                    onAction="#showProfile"/>
                <Separator styleClass="sidebar-divider"/>
                <Button
                    fx:id="sidebarBids"
                    text="🎯  My Bids"
                    styleClass="sidebar-item"
                    onAction="#showMyBids"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Separator styleClass="sidebar-divider"/>
                <Button
                    text="🚪  Logout"
                    styleClass="sidebar-item"
                    onAction="#handleLogout"/>
            </VBox>

            <!-- ── Dynamic content area ── -->
            <VBox HBox.hgrow="ALWAYS" styleClass="content-area">

                <!-- Back button — hidden by default -->
                <Button
                    fx:id="backButton"
                    text="← Back to Auctions"
                    styleClass="back-button"
                    visible="false"
                    managed="false"
                    onAction="#goBack"/>

                <!-- Content stack — swap pages here -->
                <StackPane fx:id="contentStack" VBox.vgrow="ALWAYS">

                    <!-- ── Auctions page (default) ── -->
                    <VBox fx:id="auctionsPage" visible="true" managed="true" spacing="16">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="Active Auctions" styleClass="content-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Reset" styleClass="dash-secondary-button" onAction="#handleResetAuctions"/>
                        </HBox>
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="edge-to-edge">
                            <VBox fx:id="auctionsList" spacing="14"/>
                        </ScrollPane>
                    </VBox>

                    <!-- ── Inventory page ── -->
                    <VBox fx:id="inventoryPage" visible="false" managed="false" spacing="16">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="My Inventory" styleClass="content-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Reset" styleClass="dash-secondary-button" onAction="#handleResetInventory"/>
                        </HBox>
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                            <VBox fx:id="inventoryList" spacing="12"/>
                        </ScrollPane>
                    </VBox>

                    <!-- ── Create Auction page ── -->
                    <VBox fx:id="createAuctionPage" visible="false" managed="false" spacing="16" maxWidth="500">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="Create Auction" styleClass="content-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Reset" styleClass="dash-secondary-button" onAction="#handleResetCreateAuction"/>
                        </HBox>
                        <Label text="Item" styleClass="form-label"/>
                        <ComboBox fx:id="itemComboBox" promptText="Select item from inventory" maxWidth="Infinity" styleClass="dash-input"/>
                        <Label text="Starting Price ($)" styleClass="form-label"/>
                        <TextField fx:id="startingPriceField" promptText="0.00" styleClass="dash-input"/>
                        <Label text="Start Date" styleClass="form-label"/>
                        <DatePicker fx:id="startDatePicker" styleClass="dash-input"/>
                        <Label text="Start Time (HH:MM)" styleClass="form-label"/>
                        <TextField fx:id="startTimeInput" promptText="10:00" styleClass="dash-input"/>
                        <Label text="End Date" styleClass="form-label"/>
                        <DatePicker fx:id="endDatePicker" styleClass="dash-input"/>
                        <Label text="End Time (HH:MM)" styleClass="form-label"/>
                        <TextField fx:id="endTimeInput" promptText="12:00" styleClass="dash-input"/>
                        <Label fx:id="createAuctionError" visible="false" managed="false" styleClass="error-label"/>
                        <Button text="Create Auction" styleClass="dash-primary-button" onAction="#handleCreateAuction"/>
                    </VBox>

                    <!-- ── Profile page ── -->
                    <VBox fx:id="profilePage" visible="false" managed="false" spacing="20" maxWidth="500">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="My Profile" styleClass="content-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Reset" styleClass="dash-secondary-button" onAction="#handleResetProfile"/>
                        </HBox>
                        <VBox styleClass="inventory-card" spacing="8">
                            <Label text="BALANCE" styleClass="profile-label"/>
                            <Label fx:id="profileBalance" styleClass="profile-balance"/>
                        </VBox>
                        <VBox styleClass="inventory-card" spacing="8">
                            <Label text="USERNAME" styleClass="profile-label"/>
                            <Label fx:id="profileUsername" text="—" styleClass="profile-value"/>
                            <Label text="EMAIL" styleClass="profile-label"/>
                            <Label fx:id="profileEmail" text="—" styleClass="profile-value"/>
                        </VBox>
                        <Button text="🚪 Logout" styleClass="dash-danger-button" onAction="#handleLogout"/>
                    </VBox>

                    <!-- ── My Bids page ── -->
                    <VBox fx:id="myBidsPage" visible="false" managed="false" spacing="16">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="My Bids" styleClass="content-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Reset" styleClass="dash-secondary-button" onAction="#handleResetMyBids"/>
                        </HBox>
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                            <VBox fx:id="myBidsList" spacing="12"/>
                        </ScrollPane>
                    </VBox>

                    <!-- ── Auction Detail page ── -->
                    <VBox fx:id="auctionDetailPage" visible="false" managed="false" spacing="16" maxWidth="500">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label fx:id="auctionDetailTitle" text="Auction Details" styleClass="content-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Reset" styleClass="dash-secondary-button" onAction="#handleResetAuctionDetail"/>
                        </HBox>
                        <VBox styleClass="inventory-card" spacing="8">
                            <Label text="ITEM" styleClass="profile-label"/>
                            <Label fx:id="detailItemName" styleClass="profile-value"/>
                            <Label text="CATEGORY" styleClass="profile-label"/>
                            <Label fx:id="detailItemCategory" styleClass="profile-value"/>
                        </VBox>
                        <VBox styleClass="inventory-card" spacing="8">
                            <Label text="SELLER" styleClass="profile-label"/>
                            <Label fx:id="detailSeller" styleClass="profile-value"/>
                            <Label text="CURRENT PRICE" styleClass="profile-label"/>
                            <Label fx:id="detailCurrentPrice" styleClass="profile-value"/>
                            <Label text="START TIME" styleClass="profile-label"/>
                            <Label fx:id="detailStartTime" styleClass="profile-value"/>
                            <Label text="END TIME" styleClass="profile-label"/>
                            <Label fx:id="detailEndTime" styleClass="profile-value"/>
                            <Label text="STATUS" styleClass="profile-label"/>
                            <Label fx:id="detailStatus" styleClass="profile-value"/>
                        </VBox>
                        <Label text="Enter Bid Amount ($)" styleClass="form-label"/>
                        <TextField fx:id="bidAmountField" promptText="0.00" styleClass="dash-input"/>
                        <Label fx:id="bidError" visible="false" managed="false" styleClass="error-label"/>
                        <Button text="Place Bid" styleClass="dash-primary-button" onAction="#handlePlaceBid"/>
                    </VBox>

                </StackPane>
            </VBox>

        </HBox>
    </center>

</BorderPane>